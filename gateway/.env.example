# 应用配置
APP_NAME=Gateway API
APP_VERSION=1.0.0
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=9000

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_CLUSTER_MODE=false
REDIS_CLUSTER_NODES=["localhost:6379","localhost:6380"]
REDIS_POOL_SIZE=10
REDIS_DECODE_RESPONSES=true
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_TTL=30

# CORS配置（动态管理，参考 /api/config/cors）
CORS_ORIGINS=["http://localhost:9527","http://127.0.0.1:9527","http://localhost:9528","http://127.0.0.1:9528","http://localhost:9529","http://127.0.0.1:9529"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]
CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-Requested-With"]

# HMAC配置
HMAC_SECRET_KEY=your-secret-key-here
HMAC_ENABLED=True
HMAC_TIMESTAMP_TOLERANCE=300

# 负载均衡策略
LOAD_BALANCER_STRATEGY=weighted_round_robin

# HTTP客户端配置
HTTP_TIMEOUT=10
REQUEST_TIMEOUT=30
HTTPS_ENABLED=false
SSL_VERIFY=false
SSL_CA_BUNDLE=
SSL_CERT_PATH=
SSL_KEY_PATH=
SSL_CERT_REQUIRED=false
SSL_PROTOCOL=
SSL_CIPHERS=
SSL_VERSION=
HTTP_MAX_KEEPALIVE=10
HTTP_MAX_CONNECTIONS=100
HTTP_HTTP2_ENABLED=false
HTTP_CONNECT_TIMEOUT=5
HTTP_READ_TIMEOUT=5
HTTP_WRITE_TIMEOUT=5
HTTP_POOL_TIMEOUT=5

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
TIMEZONE=Asia/Shanghai

# Consul配置
CONSUL_HOST=localhost
CONSUL_PORT=8500
CONSUL_ENABLED=false
CONSUL_TOKEN=
CONSUL_SCHEME=http
CONSUL_VERIFY=false
CONSUL_CLUSTER_ENABLED=false
CONSUL_CLUSTER_NODES=localhost:8500,localhost:8501,localhost:8502
CONSUL_DC=dc1

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
