# ============================================
# Gateway API 配置模板
# ============================================
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 修改下面的配置项为你的实际值
# 3. ⚠️ 标记的配置项必须修改，否则服务无法启动
# ============================================

# 应用配置
APP_NAME=Gateway API
APP_VERSION=1.0.0
DEBUG=False  # ⚠️ 生产环境必须设置为 False

# 服务器配置
HOST=0.0.0.0
PORT=9000

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password  # ⚠️ 请修改为实际密码
REDIS_DB=0
REDIS_CLUSTER_MODE=false
REDIS_CLUSTER_NODES=["localhost:6379","localhost:6380"]
REDIS_POOL_SIZE=10
REDIS_DECODE_RESPONSES=true
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_TTL=30

# CORS配置（动态管理，可通过 /api/config/cors 接口修改）
CORS_ORIGINS=["http://localhost:9527","http://127.0.0.1:9527"]  # Vue开发服务器端口
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]
CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-Requested-With","X-Signature","X-Timestamp","X-Nonce"]

# HMAC配置
HMAC_SECRET_KEY=generate-your-own-secret-key-here  # ⚠️ 必须生成一个安全的密钥（建议至少32字符）
# 生成密钥命令: python -c "import secrets; print(secrets.token_urlsafe(32))"
HMAC_ENABLED=true
HMAC_TIMESTAMP_TOLERANCE=300

# 负载均衡策略 (round_robin | weighted_round_robin | random | least_conn)
LOAD_BALANCER_STRATEGY=weighted_round_robin

# HTTP客户端配置
HTTP_TIMEOUT=10
REQUEST_TIMEOUT=30
HTTPS_ENABLED=true  # ⚠️ 生产环境建议启用 HTTPS
SSL_VERIFY=true
SSL_CA_BUNDLE=/path/to/ca-bundle.crt  # HTTPS启用时配置
SSL_CERT_PATH=/path/to/cert.pem  # HTTPS启用时配置
SSL_KEY_PATH=/path/to/key.pem  # HTTPS启用时配置
SSL_CERT_REQUIRED=false
SSL_PROTOCOL=TLSv1.2
SSL_CIPHERS=
SSL_VERSION=
HTTP_MAX_KEEPALIVE=10
HTTP_MAX_CONNECTIONS=100
HTTP_HTTP2_ENABLED=false
HTTP_CONNECT_TIMEOUT=5
HTTP_READ_TIMEOUT=5
HTTP_WRITE_TIMEOUT=5
HTTP_POOL_TIMEOUT=5

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
TIMEZONE=Asia/Shanghai

# Consul配置
CONSUL_HOST=localhost
CONSUL_PORT=8500
CONSUL_ENABLED=false  # 是否启用 Consul 服务发现
CONSUL_TOKEN=
CONSUL_SCHEME=http
CONSUL_VERIFY=false
CONSUL_CLUSTER_ENABLED=false
CONSUL_CLUSTER_NODES=localhost:8500,localhost:8501,localhost:8502
CONSUL_DC=dc1

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100  # 每时间窗口最大请求数
RATE_LIMIT_WINDOW_SECONDS=60  # 时间窗口大小（秒）